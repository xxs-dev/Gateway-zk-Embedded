{
  "runtimeMode": "ems",
  "identityConfigFile": "/opt/modbus-gateway/config/runtime/device_identity.json",
  "deviceConfigFiles": [
    "/opt/modbus-gateway/config/runtime/devices/device_slave_ttySP1.json",
    "/opt/modbus-gateway/config/runtime/devices/device_slave_ttySP2.json",
    "/opt/modbus-gateway/config/runtime/devices/device_dio.json",
    "/opt/modbus-gateway/config/runtime/devices/device_ems_virtual.json"
  ],
  "mqtt": {
    "enabled": true,
    "protocolVersion": "mqtt5",
    "broker": "tcp://127.0.0.1:1883",
    "clientId": "GW_FACTORY_001",
    "username": "",
    "password": "",
    "telemetryTopic": "edge/telemetry",
    "changeEventTopic": "edge/event/change",
    "commandRequestTopic": "edge/command/request",
    "commandReplyTopic": "edge/command/reply",
    "otaRequestTopic": "edge/ota/request",
    "otaReplyTopic": "edge/ota/reply",
    "otaStatusTopic": "edge/ota/status",
    "systemMonitorRequestTopic": "edge/system/monitor/request",
    "systemMonitorReplyTopic": "edge/system/monitor/reply",
    "systemMonitorTelemetryTopic": "edge/system/monitor/telemetry",
    "systemMonitorAlertTopic": "edge/system/monitor/alert",
    "systemMonitorPointTopic": "edge/system/monitor/points",
    "diagRequestTopic": "edge/system/diag/request",
    "diagReplyTopic": "edge/system/diag/reply",
    "configPullRequestTopic": "edge/config/pull/request",
    "configPullReplyTopic": "edge/config/pull/reply",
    "qos": 1,
    "maxPayloadBytes": 49152,
    "cleanSession": true,
    "keepAliveSec": 60,
    "sessionExpirySec": 0,
    "tls": {
      "enabled": false,
      "caFile": "",
      "certFile": "",
      "keyFile": "",
      "insecureSkipVerify": false
    },
    "offlineBuffer": {
      "enabled": false,
      "mode": "ring",
      "dir": "/opt/modbus-gateway/data/monitor-spool",
      "realtimeFile": "/opt/modbus-gateway/data/monitor-spool/realtime_ring.dat",
      "realtimeFileSizeBytes": 1073741824,
      "maxRealtimeMessageBytes": 4194304,
      "maxMemoryMessages": 200,
      "flushBatchSize": 10,
      "flushIntervalMs": 5000,
      "replayBatchSize": 20,
      "maxDiskBytes": 33554432,
      "eventOutbox": {
        "sqlitePath": "/opt/modbus-gateway/data/monitor_event_outbox.db",
        "sqliteLibraryPath": "",
        "retentionMonths": 12,
        "cleanupIntervalHours": 24,
        "replayBatchSize": 100
      }
    },
    "alarmTopic": "edge/alarm",
    "statusTopic": "edge/status"
  },
  "mqttDriver": {
    "enabled": false,
    "sharedMemoryName": "gateway_point_store",
    "sharedMemoryNames": [
      "gateway_point_store"
    ],
    "scanIntervalMs": 1000,
    "fullUploadIntervalMs": 60000,
    "snapshotBacklogThreshold": 0,
    "snapshotBackoffIntervalMs": 0,
    "eventReplayMaxBytes": 262144,
    "publishFullOnStart": false,
    "publishAllOnFull": false,
    "fullUploadIndexes": []
  },
  "alarmStore": {
    "enabled": false,
    "sqlitePath": "/opt/modbus-gateway/data/alarm_events_monitor.db",
    "sqliteLibraryPath": ""
  },
  "eventEngine": {
    "enabled": false,
    "scanIntervalMs": 100,
    "scanFallbackIntervalMs": 5000,
    "updateDrainBatchSize": 4096,
    "publishMode": "mqtt_driver_outbox",
    "mqttClientIdSuffix": "event_engine"
  },
  "computeEngine": {
    "enabled": false,
    "sharedMemoryNames": [
      "gateway_point_store"
    ],
    "outputDefaultSharedMemoryName": "gateway_point_store",
    "scanIntervalMs": 200,
    "maxRuleEvalPerScan": 1000,
    "badQuality": 0,
    "defaultOutputTtlMs": 600000,
    "maxWritesPerScan": 100,
    "rules": []
  },
  "realtime": {
    "enabled": false,
    "telemetryTopic": "edge/telemetry",
    "alarmTopic": "edge/alarm",
    "statusTopic": "edge/status",
    "maxLatestPoints": 100000,
    "trendBufferSize": 300,
    "pushThrottleMs": 200
  },
  "systemMonitor": {
    "enabled": true,
    "defaultIntervalMs": 5000,
    "minIntervalMs": 1000,
    "subscriptionTtlSec": 30,
    "cpuAlertThreshold": 90,
    "memAlertThreshold": 90,
    "diskAlertThreshold": 90,
    "alertRepeatIntervalSec": 60,
    "diagEnabled": true,
    "allowedCommands": [
      "uptime",
      "free_m",
      "df_root",
      "top_once",
      "ps_gateway",
      "journal_tail",
      "systemctl_status",
      "cellular_status"
    ],
    "cellular": {
      "enabled": true,
      "probeIntervalMs": 5000,
      "commandTimeoutMs": 2000,
      "atBaudRate": 115200,
      "signalAlertThresholdPercent": 20,
      "maskSensitiveFields": false,
      "interfacePatterns": [
        "wwan*",
        "ppp*",
        "usb*",
        "rmnet*",
        "wwp*"
      ],
      "modemDevicePatterns": [
        "/dev/ttyUSB2",
        "/dev/ttyUSB1",
        "/dev/ttyUSB0",
        "/dev/ttyUSB3",
        "/dev/ttyUSB*",
        "/dev/cdc-wdm*"
      ]
    }
  },
  "localDisplay": {
    "enabled": false,
    "renderer": "webkit",
    "bindHost": "127.0.0.1",
    "port": 18080,
    "refreshIntervalMs": 1000,
    "maxPointsPerFrame": 500,
    "showOnlyConfiguredPoints": true,
    "kiosk": {
      "width": 1280,
      "height": 720,
      "fullscreen": true,
      "setDisplayMode": true,
      "enabled": true,
      "requireDisplayConnected": true,
      "requireEdid": true,
      "displayOutput": "",
      "zoom": 1.0
    },
    "sharedMemoryNames": [
      "gateway_point_store"
    ],
    "screens": [
      {
        "screenCode": "overview",
        "title": "设备总览",
        "layout": {
          "type": "grid",
          "columns": 12,
          "rowHeight": 64,
          "gap": 12
        },
        "widgets": [
          {
            "id": "title_overview",
            "type": "groupTitle",
            "title": "网关总览",
            "text": "Gateway Local Display",
            "position": {
              "x": 0,
              "y": 0,
              "w": 12,
              "h": 1
            }
          },
          {
            "id": "online_status",
            "type": "statusCard",
            "title": "设备在线",
            "bind": {
              "index": 11000
            },
            "valueFormat": "boolOnline",
            "position": {
              "x": 0,
              "y": 1,
              "w": 3,
              "h": 2
            }
          },
          {
            "id": "key_value",
            "type": "valueCard",
            "title": "关键数值",
            "bind": {
              "index": 11000
            },
            "valueFormat": "number",
            "position": {
              "x": 3,
              "y": 1,
              "w": 3,
              "h": 2
            }
          },
          {
            "id": "key_points",
            "type": "pointTable",
            "title": "关键点表",
            "bind": {
              "indexes": [
                11000,
                11001,
                11002,
                11003,
                11004,
                11005,
                11006,
                11007,
                11008,
                11009
              ]
            },
            "columns": [
              "index",
              "meterCode",
              "pointCode",
              "name",
              "value",
              "unit",
              "quality",
              "time"
            ],
            "position": {
              "x": 0,
              "y": 3,
              "w": 12,
              "h": 6
            }
          }
        ]
      }
    ],
    "viewTemplate": {
      "enabled": false,
      "refreshIntervalMs": 5000
    }
  },
  "ota": {
    "enabled": false,
    "currentVersion": "1.0.0",
    "artifactBaseUrl": "",
    "downloadDir": "/opt/modbus-gateway/ota/monitor/downloads",
    "stagingDir": "/opt/modbus-gateway/ota/monitor/staging",
    "backupDir": "/opt/modbus-gateway/ota/monitor/backup",
    "packageType": "tar.gz",
    "applyScript": "/opt/modbus-gateway/bin/ota-apply.sh",
    "rollbackScript": "/opt/modbus-gateway/bin/ota-rollback.sh",
    "checksumRequired": true,
    "autoReboot": false,
    "retentionCount": 3,
    "statusReportIntervalSec": 5,
    "upgradeTimeoutSec": 900,
    "downloadRetryCount": 3,
    "downloadRetryBackoffMs": 1000,
    "storage": {
      "provider": "local",
      "presignExpireMinutes": 60,
      "minio": {
        "endpoint": "http://127.0.0.1:9000",
        "accessKey": "minioadmin",
        "secretKey": "minioadmin",
        "bucket": "edge-ota",
        "basePath": "packages",
        "publicBaseUrl": ""
      }
    }
  }
}
