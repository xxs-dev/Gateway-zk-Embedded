{
  "computeEngine": {
    "enabled": true,
    "scanIntervalMs": 1000,
    "defaultOutputTtlMs": 600000,
    "rules": [
      {
        "ruleCode": "shuntong_graph_ems",
        "name": "Shuntong Graph EMS",
        "enabled": true,
        "trigger": {
          "type": "interval",
          "intervalMs": 1000
        },
        "script": {
          "type": "graphEms",
          "graphFile": "runtime/logic/shuntong_ems_graph.json",
          "graphProfile": {
            "PCS_MODEL": "3",
            "BMS_MODEL": "2",
            "ZL_MODEL": "21",
            "Meter_TQ": "1",
            "Meter_CN": "1",
            "Meter_BW": "0",
            "Meter_FH": "0",
            "UPS_MODEL": "0",
            "DEHUMIDIFIER_MODEL": "0",
            "XF_CZ": "1"
          }
        }
      }
    ]
  }
}
