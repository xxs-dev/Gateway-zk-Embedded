        "enabled": true,
        "fullUpload": false,
        "read": {
          "enable": false
        },
        "write": {
          "enable": true,
          "dataType": "single_command",
          "allowedValues": [0, 1],
          "iec": {
            "ioa": 3001,
            "typeId": 45,
            "commonAddress": 1,
            "selectBeforeExecute": true,
            "waitActivationTermination": true,
            "timeoutMs": 3000
          }
        }
      }
    ],
    "telesetting": [
      {
        "index": 410004,
