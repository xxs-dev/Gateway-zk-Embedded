        "read": {
          "enable": false
        },
        "write": {
          "enable": true,
          "dataType": "setpoint_float",
          "min": -100000,
          "max": 100000,
          "iec": {
            "ioa": 4001,
            "typeId": 50,
            "commonAddress": 1,
            "selectBeforeExecute": false,
            "waitActivationTermination": true,
