{
  "schemaVersion": "1.0.0",
  "enabled": true,
  "protocol": {
    "type": "iec104",
    "tcp": {
      "host": "192.168.22.200",
      "port": 2404,
      "connectTimeoutMs": 1000,
      "timeoutMs": 1000
    },
    "iec": {
      "transportMode": "tcp",
      "commonAddress": 1,
      "cotSize": 2,
      "caSize": 2,
      "ioaSize": 3,
      "interrogationQualifier": 20,
      "pollTimeoutMs": 1000,
      "idleReadTimeoutMs": 50,
      "maxPollFrames": 64,
      "pollOnCollect": true
    }
  },
  "collect": {
    "defaultIntervalMs": 1000,
    "batchOptimize": false,
    "maxBatchRegisters": 1
  },
  "memoryStore": {
    "enabled": true,
    "backend": "shared_memory",
    "sharedMemoryName": "gateway_point_store",
    "sqlitePath": "/opt/modbus-gateway/data/point_samples_iec104.db",
    "persistFlushIntervalMs": 60000
  },
  "points": [
    {
      "index": 410001,
      "pointCode": "iec104_remote_signal_1",
      "name": "IEC104 遥信 1",
      "category": "telemetry",
      "address": 1001,
      "enabled": true,
      "fullUpload": true,
      "read": {
        "enable": true,
        "dataType": "single_point",
        "intervalMs": 1000,
        "unit": "",
        "iec": {
          "ioa": 1001,
          "typeId": 1,
          "commonAddress": 1
        }
      },
      "write": {
        "enable": false
      }
    },
    {
      "index": 410002,
      "pointCode": "iec104_measured_float_1",
      "name": "IEC104 浮点遥测 1",
      "category": "telemetry",
      "address": 2001,
      "enabled": true,
      "fullUpload": true,
      "read": {
        "enable": true,
        "dataType": "measured_float",
        "scale": 1,
        "offset": 0,
        "intervalMs": 1000,
        "unit": "kW",
        "iec": {
          "ioa": 2001,
          "typeId": 13,
          "commonAddress": 1
        }
      },
      "write": {
        "enable": false
      }
    }
  ],
  "meters": []
}
