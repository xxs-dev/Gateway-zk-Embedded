[Unit]
Description=KY EMS legacy Qt display data bridge
After=gateway-services.service

[Service]
Type=simple
ExecStart=/opt/modbus-gateway/bin/QtDisplayBridge --app-config /opt/modbus-gateway/config/runtime/apps/mqtt-service.json --var-list /root/VarList.xml --interval-ms 1000
Restart=always
RestartSec=3
StandardOutput=append:/var/log/apps/qt-display-bridge.log
StandardError=append:/var/log/apps/qt-display-bridge.log

[Install]
WantedBy=multi-user.target
